# .env.example — Copy this to .env and fill in your API keys.
# Run: cp .env.example .env

# ── Required: AI & Media APIs ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...
PEXELS_API_KEY=...

# ── Required: YouTube OAuth ────────────────────────────────────
# Path to the client_secrets.json downloaded from Google Cloud Console.
# See SETTINGS.md for setup instructions.
YOUTUBE_CLIENT_SECRETS=client_secrets.json
# Hosted (Railway) OAuth Web client credentials
YOUTUBE_WEB_CLIENT_ID=
YOUTUBE_WEB_CLIENT_SECRET=

# ── Optional: ElevenLabs Voice ────────────────────────────────
# Default is "George" (clear English, authoritative).
# Other options:
#   TX3LPaxmHKxFdv7VOQHJ  Liam  — young, energetic
#   pNInz6obpgDQGcFmaJgB  Adam  — deep, serious
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ── Channel Settings ──────────────────────────────────────────
CHANNEL_NICHE=personal finance
CHANNEL_LANGUAGE=hinglish
CHANNEL_AUDIENCE=South Asia and Gulf
VIDEOS_PER_WEEK=5
SCHEDULER_PUBLISH_TIME=14:00
# Optional: override with multiple daily publish times, comma-separated.
# Example: 02:00,14:00
SCHEDULER_PUBLISH_TIMES=
# ── YouTube Publish Settings ──────────────────────────────────
# public | unlisted | private  (set in HTML dashboard → Settings → YouTube)
DEFAULT_VISIBILITY=public
# 22=People&Blogs  27=Education  26=How-to  25=News  28=Science
YOUTUBE_CATEGORY_ID=22

# ── Voice Tuning ──────────────────────────────────────────────
# Exported automatically by HTML dashboard → Settings → ElevenLabs → Voice tuning
VOICE_STABILITY=0.48
VOICE_SIMILARITY=0.82
VOICE_STYLE=0.35
# ── File Paths (Docker defaults shown) ───────────────────────
# DB_PATH=/app/data/yt_automation.db
# AUDIO_DIR=/app/audio
# IMAGES_DIR=/app/images
# OUTPUT_DIR=/app/output

# ── Visual Mode ───────────────────────────────────────────────
# images = static Pexels images (fast) | videos = Pexels MP4 clips (better)
# animated = AI generated animation via Kling AI (~$0.14/clip)
VISUAL_MODE=videos

# ── Companion Shorts Visual Mode (optional) ────────────────────
# Override visual mode for the 2 companion shorts extracted FROM each main video.
# Leave blank to use VISUAL_MODE for both long videos and companion shorts.
# Set to 'animated' to use Kling AI for companion shorts while keeping main videos on Pexels.
# Cost-effective: ~3-4 clips/short (~$0.42-0.56) vs 8-10/video (~$1.12-1.40)
#
# TWO TYPES OF SHORTS:
# 1. COMPANION SHORTS (this setting):
#    - Extracted FROM main video during normal pipeline
#    - Uses build_shorts() with existing segments
#    - 2 shorts per video (configured in dashboard)
#    - Output: output/shorts/{title}-short-1.mp4
#
# 2. STANDALONE ANIMATED SHORTS (always Kling):
#    - Created independently via /api/shorts/generate-animated
#    - NOT derived from main video - pure short-form content
#    - Uses shorts_pipeline.py with topic + hooks
#    - Output: output/shorts_animated/{job_id}/clip.mp4
#
# Examples:
#   VISUAL_MODE=videos + SHORTS_VISUAL_MODE=animated → Pexels videos + Kling companion shorts
#   VISUAL_MODE=images + SHORTS_VISUAL_MODE=animated → Pexels images + Kling companion shorts
#   VISUAL_MODE=videos + SHORTS_VISUAL_MODE=videos   → All Pexels (cheapest)
SHORTS_VISUAL_MODE=

# ── Kling AI Animated Visuals (optional) ────────────────────────────────────
# Get your key pair from https://klingai.com/dev → API Keys
# Leave blank to disable. Set VISUAL_MODE=animated to use.
KLING_API_KEY=
KLING_API_SECRET=

# ── Video Production ──────────────────────────────────────────
# Ken Burns slow-zoom percentage per clip (0.0 = disabled, 0.05 = 5%)
KEN_BURNS_ZOOM=0.05
# Crossfade dissolve between segments in seconds (0 = hard cut)
CROSSFADE_DURATION=0.4
# Background music volume in dB under narration (negative = quieter)
BG_MUSIC_VOLUME_DB=-8
# Path to .mp3 background music file (empty = no music)
BG_MUSIC_PATH=
# Branded intro/outro duration in seconds (0 = disabled)
INTRO_DURATION=4
OUTRO_DURATION=5
